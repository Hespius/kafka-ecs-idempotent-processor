# Kafka Settings
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=events
KAFKA_CONSUMER_GROUP=event_processor_group

# AWS Settings (for LocalStack)
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Application Settings
IDEMPOTENCY_TABLE_NAME=idempotency-keys
S3_BUCKET_NAME=processed-events
SQS_QUEUE_URL=http://localstack:4566/000000000000/event_notifications